{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "DISABLE_HMR=false next dev",
    "dev:no-hmr": "DISABLE_HMR=true next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:eslint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck",
    "pages:build": "rm -rf .next .vercel/output && ENABLE_EXPERIMENTAL_COREPACK=1 pnpm dlx @cloudflare/next-on-pages@1",
    "pages:preview": "pnpm run pages:build && pnpm dlx wrangler pages dev .vercel/output/static",
    "pages:deploy": "pnpm run pages:build && pnpm dlx wrangler pages deploy .vercel/output/static --project-name=imagine-workbench --commit-dirty=true",
    "test:providers": "tsc -p tests/tsconfig.json && node --test .tmp/provider-tests/tests/*.test.js",
    "trellis": "trellis",
    "clean": "rm -rf .next/types",
    "local": "bash scripts/run-local.sh"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "pannellum": "^2.5.7",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mindfoldhq/trellis": "^0.5.19",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/pannellum": "^2.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/retry": "^0.12.5",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "oxlint": "^1.68.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
