{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:eslint": "eslint .",
    "typecheck": "vp exec tsc --noEmit",
    "check": "vp run lint && vp run typecheck",
    "pages:build": "vp run build && vp dlx @cloudflare/next-on-pages@1 --skip-build",
    "pages:preview": "vp run pages:build && vp dlx wrangler pages dev .vercel/output/static",
    "pages:deploy": "vp run pages:build && vp dlx wrangler pages deploy .vercel/output/static --project-name=imagine-workbench --commit-dirty=true",
    "test:providers": "vp exec tsc -p tests/tsconfig.json && node --test .tmp/provider-tests/tests/*.test.js",
    "trellis": "trellis",
    "clean": "next clean"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@xyflow/react": "^12.10.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mindfoldhq/trellis": "^0.5.19",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/retry": "^0.12.5",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "oxlint": "^1.68.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite-plus": "^0.1.24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
