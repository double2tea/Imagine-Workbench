{
  "name": "imagine-workbench",
  "version": "0.1.0",
  "description": "Browser-first AI creative workstation for image, video, audio, and agent-assisted visual workflows.",
  "private": true,
  "homepage": "https://imagine-workbench.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/double2tea/Imagine-Workbench.git"
  },
  "bugs": {
    "url": "https://github.com/double2tea/Imagine-Workbench/issues"
  },
  "keywords": [
    "ai",
    "creative-tools",
    "image-generation",
    "video-generation",
    "audio-generation",
    "nextjs",
    "workflow"
  ],
  "author": {
    "name": "double2tea",
    "email": "double_tea@foxmail.com",
    "url": "https://github.com/double2tea"
  },
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "DISABLE_HMR=false next dev",
    "dev:no-hmr": "DISABLE_HMR=true next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:eslint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run check:version && pnpm run check:model-capabilities",
    "check:version": "node scripts/check-app-version.mjs",
    "generate:model-capabilities": "tsc -p scripts/tsconfig.model-catalog.json && node .tmp/model-catalog-generator/scripts/generate-model-capabilities.js",
    "check:model-capabilities": "tsc -p scripts/tsconfig.model-catalog.json && IMAGINE_COMPILED_ALIAS_ROOT=.tmp/model-catalog-generator node -r ./scripts/register-compiled-alias.cjs .tmp/model-catalog-generator/scripts/generate-model-capabilities.js --check",
    "check:light-contrast": "node scripts/check-light-contrast.mjs",
    "check:theme-colors": "node scripts/check-light-contrast.mjs",
    "test:e2e:audio": "node scripts/e2e-audio-workflow.mjs",
    "pages:build": "node scripts/build-cloudflare-pages.mjs",
    "pages:preview": "pnpm run pages:build && pnpm dlx wrangler pages dev .vercel/output/static",
    "pages:deploy": "pnpm run pages:build && pnpm dlx wrangler pages deploy .vercel/output/static --project-name=imagine-workbench --commit-dirty=true",
    "test:providers": "tsc -p tests/tsconfig.json && IMAGINE_COMPILED_ALIAS_ROOT=.tmp/provider-tests node -r ./scripts/register-compiled-alias.cjs --test .tmp/provider-tests/tests/*.test.js",
    "clean": "rm -rf .next/types",
    "local": "bash scripts/run-local.sh"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@xyflow/react": "^12.11.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.40.0",
    "next": "^15.4.9",
    "pannellum": "^2.5.7",
    "postcss": "^8.5.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.3.1",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/pannellum": "^2.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@types/retry": "^0.12.5",
    "@types/three": "^0.184.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.22.0",
    "oxlint": "^1.70.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
