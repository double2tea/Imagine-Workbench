# 12AI: default provider for chat, image, async image, and Veo adapters.
TWELVE_AI_API_KEY="sk_your_12ai_key"
TWELVE_AI_BASE_URL="https://cdn.12ai.org"
TWELVE_AI_VIDEO_BASE_URL="https://new.12ai.org"

# Optional: protects plugin-facing /v1/* OpenAI-compatible gateway routes.
# When set, external callers must send Authorization: Bearer <OPENAI_COMPAT_API_KEY>.
# OPENAI_COMPAT_API_KEY="local_gateway_key"

# grok2api: optional self-hosted OpenAI-compatible gateway.
GROK2API_API_KEY="your_grok2api_key"
GROK2API_BASE_URL="http://localhost:8000"

# MiMo: Xiaomi MiMo Open Platform for chat and standalone TTS API routes.
MIMO_API_KEY="your_mimo_api_key"
MIMO_BASE_URL="https://api.xiaomimimo.com"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional PostgreSQL team storage mode.
# Leave these unset for the default browser IndexedDB workflow.
# IMAGINE_STORAGE_TARGET="postgres"
# DATABASE_URL="postgresql://imagine:imagine_password@db:5432/imagine_workbench"
# IMAGINE_MEDIA_DIR="/data/imagine-media"
# IMAGINE_TEAM_SETUP_TOKEN="replace_with_a_long_random_setup_token"
# IMAGINE_TRUSTED_ORIGINS="http://localhost:3000"
